rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getUserStatus() {
      return getUserData().status;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isModerator() {
      return isAuthenticated() && getUserRole() == 'moderator';
    }

    function isSupport() {
      return isAuthenticated() && getUserRole() == 'support';
    }

    function isManager() {
      return isAdmin() || isModerator();
    }

    function isStaff() {
      return isManager() || isSupport();
    }

    function isUserActive() {
      let status = getUserStatus();
      return status == 'active';
    }

    // Usuário só pode editar campos básicos do próprio perfil.
    function isOwnerProfileUpdateSafe() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.status == resource.data.status
        && request.resource.data.paymentStatus == resource.data.paymentStatus
        && request.resource.data.verifiedEmail == resource.data.verifiedEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.deletedAt == resource.data.deletedAt
        && request.resource.data.blockReason == resource.data.blockReason
        && request.resource.data.transactionCount == resource.data.transactionCount
        && request.resource.data.billing == resource.data.billing;
    }

    match /users/{userId} {
      allow list: if isManager();
      allow get: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) || isAdmin();

      allow update: if
        (isOwner(userId) && isUserActive() && isOwnerProfileUpdateSafe())
        || isManager();

      allow delete: if isAdmin();

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isManager();
        allow create: if isOwner(userId) && isUserActive();
        allow update, delete: if
          isManager()
          || (isOwner(userId) && isUserActive() && resource.data.isArchived != true);
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId) || isStaff();
        allow create, update, delete: if isOwner(userId) && isUserActive();
      }

      match /accounts/{accountId} {
        allow read: if isOwner(userId) || isManager();
        allow create, update, delete: if isOwner(userId) && isUserActive();
      }

      match /installments/{installmentId} {
        allow read: if isOwner(userId) || isManager();
        allow create, update, delete: if isOwner(userId) && isUserActive();
      }
    }

    match /support_requests/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow read: if isStaff() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow update: if
        isAdmin()
        || isModerator()
        || (isSupport()
          && (
            resource.data.assignedTo == request.auth.uid
            || request.resource.data.assignedTo == request.auth.uid
          ));
      allow delete: if isAdmin();
    }

    // Auditoria de billing não deve ser acessível pelo client comum.
    match /billing_events/{eventId} {
      allow read: if isManager();
      allow write: if false;
    }

    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
